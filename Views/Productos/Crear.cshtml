@model Inventario360.Models.SalidaDeBodega

@{
    ViewData["Title"] = "Registrar Salida de Bodega";
}

<div class="container mt-5">
    <h2 class="mb-4">Registrar Salida de Bodega</h2>

    <form asp-action="Crear" method="post">
        <div class="mb-3">
            <label for="productoBusqueda" class="form-label">Buscar Producto</label>
            <input type="text" id="productoBusqueda" class="form-control" placeholder="Ingrese nombre o código del producto...">
        </div>

        <div class="mb-3">
            <label class="form-label">Seleccione Producto</label>
            <select id="productoSeleccionado" class="form-select">
                <option value="">Seleccione un producto</option>
                @foreach (var producto in ViewBag.Productos)
                {
                    <option value="@producto.ITEM" data-nombre="@producto.NombreTecnico">@producto.NombreTecnico</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Cantidad</label>
            <input type="number" id="cantidadProducto" class="form-control">
        </div>

        <button type="button" id="agregarProducto" class="btn btn-success">Agregar Producto</button>

        <h4 class="mt-4">Productos Seleccionados</h4>
        <table class="table table-striped" id="tablaProductos">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

        <input type="hidden" id="productosJson" name="productosJson" />

        <div class="mb-3">
            <label asp-for="Solicitante" class="form-label">Solicitante</label>
            <select asp-for="Solicitante" class="form-select" required>
                <option value="">Seleccione un empleado</option>
                @foreach (var empleado in ViewBag.Empleados)
                {
                    <option value="@empleado.ID">@empleado.Nombre</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="ResponsableEntrega" class="form-label">Responsable de Entrega</label>
            <select asp-for="ResponsableEntrega" class="form-select" required>
                <option value="">Seleccione un empleado</option>
                @foreach (var empleado in ViewBag.Empleados)
                {
                    <option value="@empleado.ID">@empleado.Nombre</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="ProyectoAsignado" class="form-label">Proyecto Asignado</label>
            <select asp-for="ProyectoAsignado" class="form-select" required>
                <option value="">Seleccione un proyecto</option>
                @foreach (var proyecto in ViewBag.Proyectos)
                {
                    <option value="@proyecto.ID">@proyecto.Nombre</option>
                }
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Registrar Salida</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>

@section Scripts {
    <script>
        let productosSeleccionados = [];

        document.getElementById("productoBusqueda").addEventListener("input", function () {
            let searchValue = this.value.toLowerCase();
            let select = document.getElementById("productoSeleccionado");
            for (let option of select.options) {
                option.hidden = !option.text.toLowerCase().includes(searchValue);
            }
        });

        document.getElementById("agregarProducto").addEventListener("click", function () {
            let select = document.getElementById("productoSeleccionado");
            let cantidadInput = document.getElementById("cantidadProducto");

            let productoId = select.value;
            let productoNombre = select.options[select.selectedIndex].text;
            let cantidad = cantidadInput.value;

            if (!productoId || cantidad <= 0) {
                alert("Seleccione un producto y una cantidad válida.");
                return;
            }

            productosSeleccionados.push({ productoId, productoNombre, cantidad });

            let tbody = document.getElementById("tablaProductos").querySelector("tbody");
            let fila = `<tr>
                <td>${productoNombre}</td>
                <td>${cantidad}</td>
                <td><button type="button" class="btn btn-danger btn-sm" onclick="eliminarProducto(${productoId})">Eliminar</button></td>
            </tr>`;

            tbody.insertAdjacentHTML("beforeend", fila);
            document.getElementById("productosJson").value = JSON.stringify(productosSeleccionados);
            cantidadInput.value = "";
        });

        function eliminarProducto(id) {
            productosSeleccionados = productosSeleccionados.filter(p => p.productoId != id);
            document.getElementById("productosJson").value = JSON.stringify(productosSeleccionados);
            let tbody = document.getElementById("tablaProductos").querySelector("tbody");
            tbody.innerHTML = "";
            productosSeleccionados.forEach(p => {
                tbody.insertAdjacentHTML("beforeend", `<tr>
                    <td>${p.productoNombre}</td>
                    <td>${p.cantidad}</td>
                    <td><button type="button" class="btn btn-danger btn-sm" onclick="eliminarProducto(${p.productoId})">Eliminar</button></td>
                </tr>`);
            });
        }
    </script>
}
